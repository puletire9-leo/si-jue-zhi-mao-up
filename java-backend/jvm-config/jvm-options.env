# JVM 调优配置
# 适用于 Spring Boot 3.x + Java 17+ 应用
# 根据服务器配置（8核16G）优化

# ==================== 内存配置 ====================
# 堆内存配置 - 推荐为系统总内存的50-75%
-Xms2g                    # 初始堆大小
-Xmx2g                    # 最大堆大小（建议与-Xms相同避免动态扩展开销）

# Metaspace 配置
--XX:MetaspaceSize=256m   # 元空间初始大小
--XX:MaxMetaspaceSize=512m # 元空间最大大小

# ==================== 垃圾回收器配置 ====================
# G1GC 配置（推荐用于Java 9+，兼顾吞吐量和延迟）
-XX:+UseG1GC                        # 使用G1垃圾收集器
-XX:MaxGCPauseMillis=200            # 最大GC停顿时间目标
-XX:G1HeapRegionSize=8m             # G1堆区域大小（1MB-32MB）
-XX:InitiatingHeapOccupancyPercent=45 # 触发Mixed GC的堆占用比例
-XX:G1HeapWastePercent=5           # 堆废物百分比
-XX:G1MixedGCCountTarget=8          # Mixed GC目标次数
-XX:G1OldCSetRegionThresholdPercent=10 # 老年代回收阈值

# 备选：ZGC 配置（极低延迟，适合超低延迟场景）
# -XX:+UseZGC
# -XX:+ZGenerational
# -XX:MaxGCPauseMillis=10
# -XX:ZCollectionInterval=60

# ==================== 性能优化 ====================
# 类加载和编译优化
-XX:+AlwaysPreTouch                    # 启动时预分配所有堆内存
-XX:-UseCounterDecay                  # 禁用计数器衰减，加速编译优化
-XX:CICompilerCount=4                  # JIT编译器线程数（推荐=CPU核心数）
-XX:CompileThreshold=10000             # JIT编译触发阈值
-XX:ReservedCodeCacheSize=256m         # JIT代码缓存大小
-XX:InitialCodeCacheSize=64m           # 初始代码缓存大小

# ==================== 调试和诊断 ====================
# GC日志配置
-Xlog:gc*:file=./logs/gc-%t.log:time,uptime,level,resource:filecount=10,filesize=100m
# 等价于:
# -XX:+PrintGCDetails
# -XX:+PrintGCDateStamps
# -XX:+PrintGCCause
# -XX:+PrintAdaptiveSizePolicy
# -XX:+PrintReferenceGC
# -XX:+PrintTLAB

# OOM时生成堆转储
-XX:+HeapDumpOnOutOfMemoryError        # OOM时生成堆转储
-XX:HeapDumpPath=./logs/heapdump.hprof # 堆转储文件路径

# ==================== 网络优化 ====================
# 减少socket超时等待
-Djava.net.preferIPv4Stack=true       # 优先使用IPv4
-Dsun.net.client.defaultConnectTimeout=10000  # 连接超时
-Dsun.net.client.defaultReadTimeout=30000     # 读取超时
-Dsun.net.inetaddr.ttl=60             # DNS缓存TTL

# ==================== 容器环境优化 ====================
# 适配容器环境（K8s/Docker）
-XX:+UseContainerSupport              # 启用容器支持（Java 10+）
-XX:MaxRAMPercentage=75.0             # 最大堆占容器内存比例
-XX:MinRAMPercentage=50.0            # 最小堆占容器内存比例
-XX:+ExitOnOutOfMemoryError          # OOM时直接退出

# ==================== 实验性特性 ====================
# 线程本地变量优化
-XX:+UseTLAB                           # 线程本地分配缓冲区
-XX:TLABSize=1m                        # TLAB大小
-XX:+ResizeTLAB                        # 自动调整TLAB大小

# 分代内存比例调整（针对高并发场景）
-XX:NewRatio=2                         # 老年代/新生代比例（默认2:1）
-XX:SurvivorRatio=8                    # Eden/Survivor比例（默认8:1）
