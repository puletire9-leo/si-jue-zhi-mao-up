# FastAPI 应用配置示例
# 复制此文件为 .env 并修改配置

APP_NAME=思觉智贸
APP_VERSION=2.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# MySQL配置
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=sijue
MYSQL_PASSWORD=sijue123456
MYSQL_DATABASE=sijuelishi

# Redis配置
REDIS_HOST=redis
REDIS_PORT=6379

# Qdrant配置
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=designs

# 腾讯云COS配置 (测试权限)
COS_ENABLED=true
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=your-cos-secret-key
COS_BUCKET=your-bucket-name
COS_REGION=ap-beijing

# 安全密钥 (生产环境必须修改!)
SECRET_KEY=change-me-in-production-use-a-long-random-string
