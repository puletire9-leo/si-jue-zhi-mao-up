# ============================================
# 思觉智贸 - 统一环境变量配置
# 所有敏感信息在此配置，勿提交到 Git
# ============================================

# ============================================
# 数据库
# ============================================
MYSQL_USER=sijue
MYSQL_PASSWORD=sijue123456
MYSQL_DATABASE=sijuelishi
MYSQL_PORT=3306

# ============================================
# Redis
# ============================================
REDIS_PORT=6379

# ============================================
# Qdrant
# ============================================
QDRANT_PORT=6333

# ============================================
# 服务端口
# ============================================
JAVA_BACKEND_PORT=8080
PYTHON_BACKEND_PORT=8000
FRONTEND_PORT=80

# ============================================
# 安全 (生产必须修改!)
# ============================================
SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRATION=86400000

# ============================================
# 腾讯云 COS (测试权限)
# ============================================
COS_ENABLED=true
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=your-cos-secret-key
COS_BUCKET=sijuelishi-dev-1328246743
COS_REGION=ap-beijing

# ============================================
# 领星 COS (可选)
# ============================================
LINGXING_COS_BUCKET=lingxing-1328246743
LINGXING_COS_REGION=ap-guangzhou
LINGXING_COS_PREFIX=uploads/
