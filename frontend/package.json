{
  "name": "sijuezhimao-frontend",
  "version": "2.0.0",
  "description": "思觉智贸 - Vue 3前端",
  "type": "module",
  "scripts": {
    "dev": "node --max-old-space-size=4096 node_modules/vite/bin/vite.js --mode development",
    "dev:clean": "node scripts/cleanup.js && node --max-old-space-size=4096 node_modules/vite/bin/vite.js --mode development",
    "dev:force": "node --max-old-space-size=4096 node_modules/vite/bin/vite.js --mode development --force",
    "build": "vite build --mode production",
    "build:analyze": "vite build --mode production && npx vite-bundle-visualizer",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "type-check": "vue-tsc --noEmit",
    "cleanup": "node scripts/cleanup.js",
    "cleanup:cache": "node scripts/cleanup.js --cache-only",
    "gen:api": "openapi-ts",
    "gen:api:watch": "openapi-ts --watch",
    "cleanup:deps": "node scripts/cleanup.js --deps-only",
    "check-naming": "python ../check/check_naming_convention_advanced.py",
    "check-naming:incremental": "python ../check/check_naming_convention_advanced.py --incremental",
    "check-naming:watch": "python ../check/check_naming_convention_advanced.py --watch",
    "check-naming:report": "python ../check/check_naming_convention_advanced.py --report naming-report.md",
    "dev:development": "vite --mode development",
    "dev:production": "vite --mode production",
    "build:development": "vite build --mode development",
    "build:production": "vite build --mode production",
    "preview:development": "vite preview --mode development",
    "preview:production": "vite preview --mode production"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@pureadmin/utils": "^2.6.4",
    "@sentry/tracing": "^7.120.4",
    "@sentry/vue": "^10.37.0",
    "@types/file-saver": "^2.0.7",
    "@types/jszip": "^3.4.0",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.7.0",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.1",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.97.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.7",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.17",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.6.2",
    "jsdom": "^27.4.0",
    "prettier": "^3.3.0",
    "sass": "^1.97.2",
    "terser": "^5.30.0",
    "typescript": "^5.6.0",
    "unplugin-auto-import": "^20.3.0",
    "unplugin-vue-components": "^30.0.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.17",
    "vue-tsc": "^3.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
